<!DOCTYPE html>
<html>
<head>
  <title>Order #<%= order.id %> - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <a href="/admin/orders" class="btn btn-secondary btn-sm mb-3">&larr; Back to Orders</a>
    <h2>Order #<%= order.id %></h2>
    <div class="card mb-3">
      <div class="card-body">
        <table class="table">
          <tr><th>Product</th><td><%= order.product_name %></td></tr>
          <tr><th>Shop</th><td><%= order.shop_name %></td></tr>
          <tr><th>Unit Price</th><td>$<%= parseFloat(order.unit_price).toFixed(2) %></td></tr>
          <tr><th>Quantity</th><td><%= order.quantity %></td></tr>
          <tr><th>Total</th><td class="fw-bold text-success">$<%= parseFloat(order.total_price).toFixed(2) %></td></tr>
          <tr><th>Status</th><td>
            <% if (order.status === 'pending') { %><span class="badge bg-warning fs-6">Pending</span>
            <% } else if (order.status === 'confirmed') { %><span class="badge bg-info fs-6">Confirmed</span>
            <% } else if (order.status === 'paid') { %><span class="badge bg-success fs-6">Paid</span>
            <% } else if (order.status === 'cancelled') { %><span class="badge bg-danger fs-6">Cancelled</span>
            <% } else { %><span class="badge bg-secondary fs-6"><%= order.status %></span><% } %>
          </td></tr>
          <tr><th>Note</th><td><%= order.note || '-' %></td></tr>
          <tr><th>Created</th><td><%= new Date(order.created_at).toLocaleString() %></td></tr>
        </table>
      </div>
    </div>
    <div class="d-flex gap-2">
      <% if (order.status === 'pending') { %>
        <form method="POST" action="/admin/orders/<%= order.id %>/confirm">
          <button class="btn btn-info">✓ Confirm Order</button>
        </form>
        <form method="POST" action="/admin/orders/<%= order.id %>/cancel" onsubmit="return confirm('Cancel this order? Stock will be restored.')">
          <button class="btn btn-danger">✗ Cancel & Restore Stock</button>
        </form>
      <% } else if (order.status === 'confirmed') { %>
        <a href="/admin/orders/<%= order.id %>/payment" class="btn btn-success">💳 Process Payment</a>
        <form method="POST" action="/admin/orders/<%= order.id %>/cancel" onsubmit="return confirm('Cancel this order? Stock will be restored.')">
          <button class="btn btn-danger">✗ Cancel & Restore Stock</button>
        </form>
      <% } %>
    </div>
  </div>
</body>
</html>
