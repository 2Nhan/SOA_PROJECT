<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order #<%= order.id %> - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f7f5; }
    .card { border:0; border-radius:12px; }
    .step { text-align:center; flex:1; position:relative; }
    .step .circle { width:40px; height:40px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-weight:700; font-size:.9rem; }
    .step.active .circle { background:#198754; color:#fff; }
    .step.done .circle { background:#0d4f2b; color:#fff; }
    .step.inactive .circle { background:#dee2e6; color:#999; }
    .step-line { height:3px; flex:1; background:#dee2e6; align-self:center; }
    .step-line.done { background:#0d4f2b; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/orders" class="text-success text-decoration-none">Orders</a></li>
        <li class="breadcrumb-item active">Order #<%= order.id %></li>
      </ol>
    </nav>

    <!-- Progress -->
    <% var steps = ['Pending','Confirmed','Paid'];
       var statusIdx = order.status==='pending'?0 : order.status==='confirmed'?1 : order.status==='paid'?2 : -1; %>
    <% if (order.status !== 'cancelled') { %>
    <div class="card shadow-sm p-4 mb-4">
      <div class="d-flex align-items-center justify-content-center">
        <% steps.forEach(function(s, i) { %>
          <% if (i > 0) { %><div class="step-line <%= i <= statusIdx ? 'done' : '' %>"></div><% } %>
          <div class="step <%= i < statusIdx ? 'done' : i === statusIdx ? 'active' : 'inactive' %>">
            <div class="circle"><%= i+1 %></div>
            <div class="small mt-1 <%= i <= statusIdx ? 'fw-semibold' : 'text-muted' %>"><%= s %></div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } else { %>
    <div class="alert alert-danger border-0 rounded-3 mb-4 d-flex align-items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/></svg>
      <strong>This order has been cancelled.</strong>
    </div>
    <% } %>

    <div class="row g-4">
      <!-- Order Info -->
      <div class="col-lg-7">
        <div class="card shadow-sm p-4">
          <h5 class="fw-bold mb-3">Order Details</h5>
          <table class="table table-borderless mb-0">
            <tr><td class="text-muted" style="width:35%">Product</td><td class="fw-semibold"><%= order.product_name %></td></tr>
            <tr><td class="text-muted">Buyer</td><td><%= order.shop_name %></td></tr>
            <tr><td class="text-muted">Unit Price</td><td>$<%= parseFloat(order.unit_price).toFixed(2) %></td></tr>
            <tr><td class="text-muted">Quantity</td><td><%= order.quantity %> units</td></tr>
            <tr><td class="text-muted">Note</td><td><%= order.note || 'No note provided' %></td></tr>
            <tr><td class="text-muted">Created</td><td><%= new Date(order.created_at).toLocaleString() %></td></tr>
          </table>
        </div>
      </div>

      <!-- Total & Actions -->
      <div class="col-lg-5">
        <div class="card shadow-sm p-4 mb-3 text-center" style="background:linear-gradient(135deg,#e8f5e9,#c8e6c9)">
          <small class="text-muted text-uppercase fw-semibold">Order Total</small>
          <div class="fs-2 fw-bold" style="color:#0d4f2b">$<%= parseFloat(order.total_price).toFixed(2) %></div>
          <div>
            <span class="badge bg-<%= order.status==='pending'?'warning':order.status==='confirmed'?'info':order.status==='paid'?'success':'danger' %> fs-6"><%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %></span>
          </div>
        </div>

        <% if (order.status === 'pending') { %>
          <div class="d-grid gap-2">
            <form method="POST" action="/admin/orders/<%= order.id %>/confirm">
              <button class="btn btn-success w-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/></svg>
                Confirm Order
              </button>
            </form>
            <form method="POST" action="/admin/orders/<%= order.id %>/cancel" onsubmit="return confirm('Cancel this order? Stock will be restored.')">
              <button class="btn btn-outline-danger w-100">Cancel &amp; Restore Stock</button>
            </form>
          </div>
        <% } else if (order.status === 'confirmed') { %>
          <div class="d-grid gap-2">
            <a href="/admin/orders/<%= order.id %>/payment" class="btn btn-success">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2.5 1a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h2a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-2z"/></svg>
              Process Payment
            </a>
            <form method="POST" action="/admin/orders/<%= order.id %>/cancel" onsubmit="return confirm('Cancel this order? Stock will be restored.')">
              <button class="btn btn-outline-danger w-100">Cancel &amp; Restore Stock</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
