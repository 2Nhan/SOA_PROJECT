<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RFQ #<%= rfq.id %> - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f7f5; }
    .card { border:0; border-radius:12px; }
    .form-label { font-weight:600; font-size:.9rem; }
    .status-banner { border-radius:12px; padding:1rem 1.5rem; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/rfqs" class="text-success text-decoration-none">RFQ Requests</a></li>
        <li class="breadcrumb-item active">RFQ #<%= rfq.id %></li>
      </ol>
    </nav>

    <!-- Status Banner -->
    <% if (rfq.status === 'pending') { %>
      <div class="status-banner bg-warning bg-opacity-25 border border-warning mb-4 d-flex align-items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#856404" viewBox="0 0 16 16"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.399l-.254-.037.026-.12L8.93 6.588zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>
        <div><strong>Action Required</strong> — This RFQ is waiting for your quotation. Submit a competitive quote below.</div>
      </div>
    <% } else if (rfq.status === 'quoted') { %>
      <div class="status-banner bg-info bg-opacity-25 border border-info mb-4 d-flex align-items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#0c5460" viewBox="0 0 16 16"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.399l-.254-.037.026-.12L8.93 6.588zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>
        <div><strong>Quote Submitted</strong> — Waiting for the buyer to accept or reject your quote.</div>
      </div>
    <% } else if (rfq.status === 'accepted') { %>
      <div class="status-banner bg-success bg-opacity-25 border border-success mb-4 d-flex align-items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#155724" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
        <div><strong>Quote Accepted!</strong> — The buyer accepted your quotation. A contract may be created.</div>
      </div>
    <% } %>

    <div class="row g-4">
      <!-- Request Details -->
      <div class="col-lg-6">
        <div class="card shadow-sm p-4">
          <h5 class="fw-bold mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#0d4f2b" class="me-2" viewBox="0 0 16 16"><path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/><path d="M3 4h10v1H3V4zm0 3h10v1H3V7zm0 3h7v1H3v-1z"/></svg>
            Request Details
          </h5>
          <table class="table table-borderless mb-0">
            <tr><td class="text-muted" style="width:40%">Buyer</td><td class="fw-semibold"><%= rfq.shop_name %></td></tr>
            <tr><td class="text-muted">Product</td><td class="fw-semibold"><%= rfq.product_name %></td></tr>
            <tr><td class="text-muted">List Price</td><td>$<%= parseFloat(rfq.list_price).toFixed(2) %></td></tr>
            <tr><td class="text-muted">Requested Qty</td><td><%= rfq.quantity %> units</td></tr>
            <% if (rfq.note) { %><tr><td class="text-muted">Buyer Note</td><td><em>"<%= rfq.note %>"</em></td></tr><% } %>
            <tr><td class="text-muted">Submitted</td><td><%= new Date(rfq.created_at).toLocaleDateString() %></td></tr>
          </table>
        </div>
      </div>

      <!-- Quote Section -->
      <div class="col-lg-6">
        <% if (rfq.quote_id) { %>
          <div class="card shadow-sm p-4 border-start border-success border-3">
            <h5 class="fw-bold mb-3 text-success">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2" viewBox="0 0 16 16"><path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/></svg>
              Your Submitted Quote
            </h5>
            <div class="row g-3 mb-3">
              <div class="col-4 text-center p-3 bg-light rounded-3">
                <div class="fs-5 fw-bold text-success">$<%= parseFloat(rfq.unit_price).toFixed(2) %></div>
                <small class="text-muted">Unit Price</small>
              </div>
              <div class="col-4 text-center p-3 bg-light rounded-3">
                <div class="fs-5 fw-bold"><%= rfq.moq %></div>
                <small class="text-muted">MOQ</small>
              </div>
              <div class="col-4 text-center p-3 bg-light rounded-3">
                <div class="fs-5 fw-bold"><%= rfq.delivery_days %></div>
                <small class="text-muted">Days Delivery</small>
              </div>
            </div>
            <% if (rfq.quote_note) { %><p class="text-muted small mb-2"><strong>Note:</strong> <%= rfq.quote_note %></p><% } %>
            <div>
              <strong>Status: </strong>
              <% if (rfq.quote_status === 'pending') { %><span class="badge bg-warning">Pending</span>
              <% } else if (rfq.quote_status === 'accepted') { %><span class="badge bg-success">Accepted</span>
              <% } else { %><span class="badge bg-danger">Rejected</span><% } %>
            </div>
          </div>
        <% } else if (rfq.status === 'pending') { %>
          <div class="card shadow-sm p-4 border-start border-warning border-3">
            <h5 class="fw-bold mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#856404" class="me-2" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/></svg>
              Submit Your Quotation
            </h5>
            <form action="/admin/rfqs/<%= rfq.id %>/quote" method="POST">
              <input type="hidden" name="supplier_id" value="<%= currentUser.id %>">
              <div class="row g-3">
                <div class="col-md-6 mb-3">
                  <label class="form-label">Unit Price ($) <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input type="number" name="unit_price" class="form-control" step="0.01" min="0.01" required>
                  </div>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="form-label">Min Order Qty (MOQ)</label>
                  <input type="number" name="moq" class="form-control" min="1" value="1">
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Delivery Days</label>
                <input type="number" name="delivery_days" class="form-control" min="1" value="7">
              </div>
              <div class="mb-3">
                <label class="form-label">Note <small class="text-muted fw-normal">(optional)</small></label>
                <textarea name="note" class="form-control" rows="2" maxlength="500" placeholder="Any terms, conditions, or remarks..."></textarea>
              </div>
              <button type="submit" class="btn btn-success w-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083l6-15Zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471-.47 1.178Z"/></svg>
                Submit Quote
              </button>
            </form>
          </div>
        <% } else { %>
          <div class="card shadow-sm p-4 text-center">
            <p class="text-muted mb-0">No quote submission available for this RFQ status.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
