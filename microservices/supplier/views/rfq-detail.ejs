<!DOCTYPE html>
<html>
<head>
  <title>RFQ Detail - Supplier</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <h2>RFQ #<%= rfq.id %></h2>
    <div class="row">
      <div class="col-md-6">
        <div class="card mb-3">
          <div class="card-header">Request from Shop</div>
          <div class="card-body">
            <p><strong>Shop:</strong> <%= rfq.shop_name %></p>
            <p><strong>Product:</strong> <%= rfq.product_name %></p>
            <p><strong>List Price:</strong> $<%= parseFloat(rfq.list_price).toFixed(2) %></p>
            <p><strong>Requested Qty:</strong> <%= rfq.quantity %></p>
            <% if (rfq.note) { %><p><strong>Note:</strong> <%= rfq.note %></p><% } %>
            <p><strong>Status:</strong>
              <% if (rfq.status === 'pending') { %><span class="badge bg-warning">Needs Your Quote</span>
              <% } else if (rfq.status === 'quoted') { %><span class="badge bg-info">Quoted - Awaiting Shop</span>
              <% } else if (rfq.status === 'accepted') { %><span class="badge bg-success">Accepted</span>
              <% } else { %><span class="badge bg-secondary"><%= rfq.status %></span><% } %>
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <% if (rfq.quote_id) { %>
        <div class="card mb-3 border-success">
          <div class="card-header bg-success text-white">Your Submitted Quote</div>
          <div class="card-body">
            <p><strong>Unit Price:</strong> $<%= parseFloat(rfq.unit_price).toFixed(2) %></p>
            <p><strong>MOQ:</strong> <%= rfq.moq %></p>
            <p><strong>Delivery:</strong> <%= rfq.delivery_days %> days</p>
            <% if (rfq.quote_note) { %><p><strong>Note:</strong> <%= rfq.quote_note %></p><% } %>
            <p><strong>Status:</strong>
              <% if (rfq.quote_status === 'pending') { %><span class="badge bg-warning">Pending</span>
              <% } else if (rfq.quote_status === 'accepted') { %><span class="badge bg-success">Accepted</span>
              <% } else { %><span class="badge bg-danger">Rejected</span><% } %>
            </p>
          </div>
        </div>
        <% } else if (rfq.status === 'pending') { %>
        <div class="card mb-3 border-warning">
          <div class="card-header bg-warning">Submit Your Quotation</div>
          <div class="card-body">
            <form action="/admin/rfqs/<%= rfq.id %>/quote" method="POST">
              <input type="hidden" name="supplier_id" value="2">
              <div class="mb-3">
                <label class="form-label">Unit Price ($)</label>
                <input type="number" name="unit_price" class="form-control" step="0.01" min="0.01" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Min Order Qty (MOQ)</label>
                <input type="number" name="moq" class="form-control" min="1" value="1">
              </div>
              <div class="mb-3">
                <label class="form-label">Delivery Days</label>
                <input type="number" name="delivery_days" class="form-control" min="1" value="7">
              </div>
              <div class="mb-3">
                <label class="form-label">Note</label>
                <textarea name="note" class="form-control" rows="2" maxlength="500"></textarea>
              </div>
              <button type="submit" class="btn btn-success">Submit Quote</button>
            </form>
          </div>
        </div>
        <% } %>
      </div>
    </div>
    <a href="/admin/rfqs" class="btn btn-secondary">Back to RFQs</a>
  </div>
</body>
</html>
