<!DOCTYPE html>
<html class="h-100">
<head>
  <title>Login - Supplier Panel</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); }
    .login-card { border: none; border-radius: 16px; overflow: hidden; }
    .login-sidebar { background: linear-gradient(135deg, #0d4f2b 0%, #1a7a4a 100%); color: white; padding: 40px; display: flex; flex-direction: column; justify-content: center; }
  </style>
</head>
<body class="d-flex flex-column h-100">
  <div class="container my-auto">
    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="card login-card shadow-lg">
          <div class="row g-0">
            <div class="col-md-5 d-none d-md-block">
              <div class="login-sidebar h-100">
                <div class="mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16"><path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923z"/></svg>
                </div>
                <h3 class="fw-bold mb-3">Supplier Portal</h3>
                <p class="text-white-50 mb-4">Manage your products, respond to buyer requests, and grow your B2B businesses.</p>
                <ul class="list-unstyled small text-white-50">
                  <li class="mb-2">✓ List & manage products</li>
                  <li class="mb-2">✓ Respond to RFQs with quotes</li>
                  <li class="mb-2">✓ Confirm contracts & orders</li>
                  <li class="mb-2">✓ Process payments securely</li>
                </ul>
              </div>
            </div>
            <div class="col-md-7">
              <div class="card-body p-4 p-md-5">
                <h3 class="fw-bold mb-1">Supplier Login</h3>
                <p class="text-muted mb-4">Sign in to manage your supplier account</p>
                <% if (error) { %>
                  <div class="alert alert-<%= error.includes('successful') ? 'success' : 'danger' %> alert-dismissible py-2">
                    <small><%= error %></small>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
                  </div>
                <% } %>
                <form method="POST" action="/admin/login">
                  <div class="mb-3">
                    <label class="form-label fw-semibold small">Email Address</label>
                    <input type="email" name="email" class="form-control" required autofocus>
                  </div>
                  <div class="mb-4">
                    <label class="form-label fw-semibold small">Password</label>
                    <input type="password" name="password" class="form-control" required>
                  </div>
                  <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">Sign In</button>
                </form>
                <div class="text-center mt-4">
                  <p class="text-muted mb-0 small">Don't have an account? <a href="/admin/register" class="fw-semibold">Register here</a></p>
                </div>
                <hr class="my-4">
                <div class="bg-light rounded p-3">
                  <p class="fw-semibold small mb-2">Demo Accounts:</p>
                  <div class="small text-muted">
                    <div>📦 <strong>Supplier:</strong> supplier1@b2bmarket.com / password123</div>
                    <div>🛡️ <strong>Admin:</strong> admin@b2bmarket.com / password123</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
