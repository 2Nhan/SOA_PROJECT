<!DOCTYPE html>
<html>
<head>
  <title>Product Approval - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <h2>Product Approval Queue</h2>
    <a href="/admin/manage" class="btn btn-sm btn-secondary mb-3">Back to Admin Dashboard</a>
    <% if (products.length === 0) { %>
      <div class="alert alert-success">No pending products to review.</div>
    <% } else { %>
    <table class="table table-hover">
      <thead class="table-dark">
        <tr><th>ID</th><th>Image</th><th>Name</th><th>Supplier</th><th>Price</th><th>Stock</th><th>Category</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% products.forEach(p => { %>
        <tr>
          <td><%= p.id %></td>
          <td><% if (p.image_url) { %><img src="<%= p.image_url %>" width="50" height="50" style="object-fit:cover"><% } else { %>-<% } %></td>
          <td><%= p.name %></td>
          <td><%= p.supplier_name %></td>
          <td>$<%= parseFloat(p.price).toFixed(2) %></td>
          <td><%= p.stock %></td>
          <td><%= p.category || '-' %></td>
          <td>
            <form action="/admin/manage/products/<%= p.id %>/approve" method="POST" class="d-inline">
              <button class="btn btn-sm btn-success">Approve</button>
            </form>
            <form action="/admin/manage/products/<%= p.id %>/reject" method="POST" class="d-inline">
              <button class="btn btn-sm btn-warning">Reject</button>
            </form>
            <form action="/admin/manage/products/<%= p.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this product?')">
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</body>
</html>
