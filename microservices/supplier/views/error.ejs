<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>body { background:#f5f7f5; }</style>
</head>
<body class="d-flex flex-column min-vh-100">
  <%- include('partials/nav') %>
  <div class="flex-grow-1 d-flex align-items-center justify-content-center">
    <div class="text-center px-4" style="max-width:480px">
      <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4" style="width:80px;height:80px;background:#fff3cd">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="#856404" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
      </div>
      <h4 class="fw-bold mb-2">Something went wrong</h4>
      <p class="text-muted mb-4"><%= message %></p>
      <a href="/admin/" class="btn btn-success px-4">Back to Dashboard</a>
    </div>
  </div>
  <%- include('partials/footer') %>
</body>
</html>
