<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Contracts - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f5f5; }
    .card { border:0; border-radius:12px; }
    .table th { font-weight:600; font-size:.85rem; text-transform:uppercase; letter-spacing:.5px; color:#555; border-bottom:2px solid #dee2e6; }
    .table td { vertical-align:middle; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/manage" class="text-decoration-none" style="color:#1a1a2e">Admin Dashboard</a></li>
        <li class="breadcrumb-item active">All Contracts</li>
      </ol>
    </nav>

    <div class="mb-4">
      <h3 class="fw-bold mb-1">All Contracts — System Overview</h3>
      <p class="text-muted mb-0">Read-only view of all contracts across the platform</p>
    </div>

    <% if (contracts.length === 0) { %>
      <div class="card shadow-sm p-5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#aaa" class="mx-auto mb-3" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zM9.5 3A1.5 1.5 0 0 0 8 4.5V6h2.5L9.5 3z"/></svg>
        <h5 class="text-muted">No contracts in the system yet</h5>
      </div>
    <% } else { %>
      <div class="card shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="bg-light">
              <tr><th>#</th><th>Product</th><th>Buyer</th><th>Supplier</th><th>Qty</th><th>Total</th><th>Status</th><th>Date</th></tr>
            </thead>
            <tbody>
              <% contracts.forEach(function(c) { %>
              <tr>
                <td class="fw-semibold">#<%= c.id %></td>
                <td><%= c.product_name %></td>
                <td><%= c.shop_name %></td>
                <td><%= c.supplier_name %></td>
                <td><%= c.quantity %></td>
                <td class="fw-semibold">$<%= parseFloat(c.total_amount).toFixed(2) %></td>
                <td>
                  <% if (c.status === 'draft') { %><span class="badge bg-warning">Draft</span>
                  <% } else if (c.status === 'confirmed') { %><span class="badge bg-success">Confirmed</span>
                  <% } else if (c.status === 'completed') { %><span class="badge bg-primary">Completed</span>
                  <% } else { %><span class="badge bg-danger">Cancelled</span><% } %>
                </td>
                <td><%= new Date(c.created_at).toLocaleDateString() %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <div class="mt-3 p-3 bg-light rounded-3 d-flex align-items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6c757d" viewBox="0 0 16 16"><path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
      <small class="text-muted">This is a read-only view. Admin cannot modify contracts.</small>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
