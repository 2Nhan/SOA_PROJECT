<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contract #<%= contract.id %> - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f7f5; }
    .card { border:0; border-radius:12px; }
    .status-banner { border-radius:12px; padding:1rem 1.5rem; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/contracts" class="text-success text-decoration-none">Contracts</a></li>
        <li class="breadcrumb-item active">Contract #<%= contract.id %></li>
      </ol>
    </nav>

    <!-- Status Banner -->
    <% if (contract.status === 'draft') { %>
      <div class="status-banner bg-warning bg-opacity-25 border border-warning mb-4 d-flex align-items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#856404" viewBox="0 0 16 16"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.399l-.254-.037.026-.12L8.93 6.588zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>
        <div><strong>Action Required</strong> — Review and confirm or cancel this contract.</div>
      </div>
    <% } else if (contract.status === 'confirmed') { %>
      <div class="status-banner bg-success bg-opacity-25 border border-success mb-4 d-flex align-items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#155724" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
        <div><strong>Contract Confirmed</strong> — This contract is active and binding.</div>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-lg-7">
        <div class="card shadow-sm p-4">
          <h5 class="fw-bold mb-3">Contract Details</h5>
          <table class="table table-borderless mb-0">
            <tr><td class="text-muted" style="width:35%">Product</td><td class="fw-semibold"><%= contract.product_name %></td></tr>
            <tr><td class="text-muted">Buyer</td><td><%= contract.shop_name %></td></tr>
            <tr><td class="text-muted">Quantity</td><td><%= contract.quantity %> units</td></tr>
            <tr><td class="text-muted">Unit Price</td><td>$<%= parseFloat(contract.unit_price).toFixed(2) %></td></tr>
            <tr><td class="text-muted">Delivery</td><td><%= contract.delivery_days %> days</td></tr>
            <tr><td class="text-muted">Created</td><td><%= new Date(contract.created_at).toLocaleDateString() %></td></tr>
          </table>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="card shadow-sm p-4 mb-3 text-center" style="background:linear-gradient(135deg,#e8f5e9,#c8e6c9)">
          <small class="text-muted text-uppercase fw-semibold">Contract Value</small>
          <div class="fs-2 fw-bold" style="color:#0d4f2b">$<%= parseFloat(contract.total_amount).toFixed(2) %></div>
          <span class="badge bg-<%= contract.status==='draft'?'warning':contract.status==='confirmed'?'success':contract.status==='completed'?'primary':'danger' %> fs-6"><%= contract.status.charAt(0).toUpperCase() + contract.status.slice(1) %></span>
        </div>

        <% if (contract.status === 'draft') { %>
          <div class="d-grid gap-2">
            <form action="/admin/contracts/<%= contract.id %>/confirm" method="POST">
              <button class="btn btn-success w-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/></svg>
                Confirm Contract
              </button>
            </form>
            <form action="/admin/contracts/<%= contract.id %>/cancel" method="POST" onsubmit="return confirm('Cancel this contract?')">
              <button class="btn btn-outline-danger w-100">Cancel Contract</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
