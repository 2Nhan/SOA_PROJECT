<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <h2>System Administration</h2>
    <div class="row mt-3">
      <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
          <div class="card-body text-center">
            <h3><%= stats.totalUsers %></h3>
            <p>Total Users</p>
            <% if (stats.pendingUsers > 0) { %><span class="badge bg-warning"><%= stats.pendingUsers %> pending</span><% } %>
            <br><a href="/admin/manage/users" class="btn btn-light btn-sm mt-2">Manage Users</a>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
          <div class="card-body text-center">
            <h3><%= stats.totalProducts %></h3>
            <p>Total Products</p>
            <% if (stats.pendingProducts > 0) { %><span class="badge bg-warning"><%= stats.pendingProducts %> pending</span><% } %>
            <br><a href="/admin/manage/products" class="btn btn-light btn-sm mt-2">Approve Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
          <div class="card-body text-center">
            <h3><%= stats.totalRFQs %></h3>
            <p>Total RFQs</p>
            <br><a href="/admin/manage/rfqs" class="btn btn-light btn-sm mt-2">View RFQs</a>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-dark mb-3">
          <div class="card-body text-center">
            <h3><%= stats.totalContracts %></h3>
            <p>Total Contracts</p>
            <br><a href="/admin/manage/contracts" class="btn btn-light btn-sm mt-2">View Contracts</a>
          </div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6">
        <div class="card mb-3">
          <div class="card-body text-center">
            <h3><%= stats.totalOrders %></h3>
            <p>Total Orders</p>
            <a href="/admin/orders" class="btn btn-outline-primary btn-sm">View Orders</a>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card mb-3">
          <div class="card-body text-center">
            <h5>Quick Links</h5>
            <a href="/admin/manage/users" class="btn btn-outline-primary btn-sm m-1">Users</a>
            <a href="/admin/manage/products" class="btn btn-outline-success btn-sm m-1">Product Approval</a>
            <a href="/admin/manage/rfqs" class="btn btn-outline-info btn-sm m-1">All RFQs</a>
            <a href="/admin/manage/contracts" class="btn btn-outline-dark btn-sm m-1">All Contracts</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
