<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Product - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f7f5; }
    .card { border:0; border-radius:12px; }
    .form-label { font-weight:600; font-size:.9rem; color:#333; }
    .current-image { border-radius:12px; border:2px solid #e0e0e0; max-width:200px; max-height:200px; object-fit:cover; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/products" class="text-success text-decoration-none">My Products</a></li>
        <li class="breadcrumb-item active">Edit: <%= product.name %></li>
      </ol>
    </nav>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card shadow-sm p-4">
          <h4 class="fw-bold mb-1">Edit Product</h4>
          <p class="text-muted mb-4">Update your product information below.</p>
          <form method="POST" action="/admin/products/update/<%= product.id %>" enctype="multipart/form-data">
            <input type="hidden" name="existing_image_url" value="<%= product.image_url || '' %>">

            <div class="mb-3">
              <label class="form-label">Product Name <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control" value="<%= product.name %>" required minlength="2" maxlength="255">
            </div>

            <div class="mb-3">
              <label class="form-label">Category</label>
              <input type="text" name="category" class="form-control" value="<%= product.category || '' %>" maxlength="100">
            </div>

            <div class="mb-3">
              <label class="form-label">Description</label>
              <textarea name="description" class="form-control" rows="4" maxlength="2000"><%= product.description || '' %></textarea>
            </div>

            <div class="row g-3">
              <div class="col-md-6 mb-3">
                <label class="form-label">Unit Price ($) <span class="text-danger">*</span></label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" name="price" class="form-control" step="0.01" value="<%= product.price %>" min="0" max="999999.99" required>
                </div>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Stock Quantity <span class="text-danger">*</span></label>
                <input type="number" name="stock" class="form-control" value="<%= product.stock %>" min="0" max="1000000" required>
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label">Product Image</label>
              <% if (product.image_url) { %>
                <div class="mb-3 p-3 bg-light rounded-3 d-flex align-items-center gap-3">
                  <img src="<%= product.image_url %>" alt="<%= product.name %>" class="current-image">
                  <div>
                    <p class="mb-1 fw-semibold">Current Image</p>
                    <small class="text-muted">Upload a new file below to replace it.</small>
                  </div>
                </div>
              <% } %>
              <input type="file" name="image" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp">
              <div class="form-text">Max 5MB. Leave empty to keep current image.</div>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-success px-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/></svg>
                Update Product
              </button>
              <a href="/admin/products" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>

      <!-- Product Info Sidebar -->
      <div class="col-lg-4">
        <div class="card shadow-sm p-4 mb-3">
          <h6 class="fw-bold mb-3">Product Info</h6>
          <div class="mb-2"><small class="text-muted">Product ID</small><br><strong>#<%= product.id %></strong></div>
          <div class="mb-2"><small class="text-muted">Status</small><br><span class="badge bg-<%= product.status === 'active' ? 'success' : product.status === 'pending' ? 'warning' : 'secondary' %> fs-6"><%= product.status %></span></div>
          <% if (product.created_at) { %>
          <div><small class="text-muted">Created</small><br><strong><%= new Date(product.created_at).toLocaleDateString() %></strong></div>
          <% } %>
        </div>
        <div class="card shadow-sm p-4 border-start border-danger border-3">
          <h6 class="fw-bold text-danger mb-2">Danger Zone</h6>
          <p class="small text-muted mb-2">Permanently delete this product. This cannot be undone.</p>
          <form method="POST" action="/admin/products/delete/<%= product.id %>" onsubmit="return confirm('Are you sure you want to permanently delete this product?')">
            <button class="btn btn-outline-danger btn-sm w-100">Delete Product</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
