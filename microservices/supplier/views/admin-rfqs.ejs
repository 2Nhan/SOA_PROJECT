<!DOCTYPE html>
<html>
<head>
  <title>All RFQs - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <h2>All RFQs (System Overview)</h2>
    <a href="/admin/manage" class="btn btn-sm btn-secondary mb-3">Back to Admin Dashboard</a>
    <% if (rfqs.length === 0) { %>
      <div class="alert alert-info">No RFQs in the system yet.</div>
    <% } else { %>
    <table class="table table-hover">
      <thead class="table-dark">
        <tr><th>#</th><th>Product</th><th>Shop</th><th>Supplier</th><th>Qty</th><th>Status</th><th>Date</th></tr>
      </thead>
      <tbody>
        <% rfqs.forEach(r => { %>
        <tr>
          <td><%= r.id %></td>
          <td><%= r.product_name %></td>
          <td><%= r.shop_name %></td>
          <td><%= r.supplier_name %></td>
          <td><%= r.quantity %></td>
          <td>
            <% if (r.status === 'pending') { %><span class="badge bg-warning">Pending</span>
            <% } else if (r.status === 'quoted') { %><span class="badge bg-info">Quoted</span>
            <% } else if (r.status === 'accepted') { %><span class="badge bg-success">Accepted</span>
            <% } else { %><span class="badge bg-secondary"><%= r.status %></span><% } %>
          </td>
          <td><%= new Date(r.created_at).toLocaleDateString() %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</body>
</html>
