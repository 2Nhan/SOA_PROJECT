<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Products - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f7f5; }
    .card { border:0; border-radius:12px; }
    .stat-card { transition:transform .2s; }
    .stat-card:hover { transform:translateY(-3px); }
    .product-img { width:56px; height:56px; object-fit:cover; border-radius:8px; }
    .product-placeholder { width:56px; height:56px; border-radius:8px; background:linear-gradient(135deg,#e8f5e9,#c8e6c9); display:flex; align-items:center; justify-content:center; }
    .table th { font-weight:600; font-size:.85rem; text-transform:uppercase; letter-spacing:.5px; color:#555; border-bottom:2px solid #dee2e6; }
    .table td { vertical-align:middle; }
    .badge { font-weight:500; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h3 class="fw-bold mb-1">My Products</h3>
        <p class="text-muted mb-0">Manage your product catalog</p>
      </div>
      <a href="/admin/products/add" class="btn btn-success px-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/></svg>
        Add Product
      </a>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <% var active=0, inactive=0, totalStock=0;
         products.forEach(function(p){ if(p.status==='active') active++; else inactive++; totalStock+=parseInt(p.stock)||0; }); %>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold text-success"><%= products.length %></div>
          <small class="text-muted">Total Products</small>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold text-primary"><%= active %></div>
          <small class="text-muted">Active</small>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold text-secondary"><%= inactive %></div>
          <small class="text-muted">Inactive / Pending</small>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold" style="color:#0d4f2b"><%= totalStock.toLocaleString() %></div>
          <small class="text-muted">Total Stock Units</small>
        </div>
      </div>
    </div>

    <!-- Table -->
    <% if (products.length === 0) { %>
      <div class="card shadow-sm p-5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#aaa" class="mx-auto mb-3" viewBox="0 0 16 16"><path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5 8 5.961 14.154 3.5 8.186 1.113zM15 4.239l-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923l6.5 2.6z"/></svg>
        <h5 class="text-muted">No products yet</h5>
        <p class="text-muted mb-3">Start building your catalog by adding your first product.</p>
        <div><a href="/admin/products/add" class="btn btn-success">Add Your First Product</a></div>
      </div>
    <% } else { %>
      <div class="card shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="bg-light">
              <tr><th style="width:70px">Image</th><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
              <% products.forEach(function(p) { %>
              <tr>
                <td>
                  <% if (p.image_url) { %>
                    <img src="<%= p.image_url %>" alt="<%= p.name %>" class="product-img">
                  <% } else { %>
                    <div class="product-placeholder">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#4caf50" viewBox="0 0 16 16"><path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5 8 5.961 14.154 3.5 8.186 1.113zM15 4.239l-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923l6.5 2.6z"/></svg>
                    </div>
                  <% } %>
                </td>
                <td>
                  <strong><%= p.name %></strong>
                  <% if (p.supplier_name) { %><br><small class="text-muted"><%= p.supplier_name %></small><% } %>
                </td>
                <td><span class="badge bg-light text-dark border"><%= p.category || 'Uncategorized' %></span></td>
                <td class="fw-semibold">$<%= parseFloat(p.price).toFixed(2) %></td>
                <td>
                  <% if (parseInt(p.stock) <= 5) { %>
                    <span class="text-danger fw-bold"><%= p.stock %></span>
                    <small class="text-danger">Low</small>
                  <% } else { %>
                    <%= p.stock %>
                  <% } %>
                </td>
                <td><span class="badge bg-<%= p.status === 'active' ? 'success' : p.status === 'pending' ? 'warning' : 'secondary' %>"><%= p.status %></span></td>
                <td class="text-end">
                  <a href="/admin/products/edit/<%= p.id %>" class="btn btn-sm btn-outline-primary me-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10z"/></svg>
                    Edit
                  </a>
                  <form method="POST" action="/admin/products/delete/<%= p.id %>" style="display:inline" onsubmit="return confirm('Delete this product permanently?')">
                    <button class="btn btn-sm btn-outline-danger">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1z"/></svg>
                      Delete
                    </button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
