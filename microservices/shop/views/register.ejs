<!DOCTYPE html>
<html class="h-100">
<head>
  <title>Register - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); }
    .register-card { border: none; border-radius: 16px; overflow: hidden; }
    .register-sidebar { background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); color: white; padding: 40px; display: flex; flex-direction: column; justify-content: center; }
  </style>
</head>
<body class="d-flex flex-column h-100">
  <div class="container my-auto py-4">
    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="card register-card shadow-lg">
          <div class="row g-0">
            <div class="col-md-5 d-none d-md-block">
              <div class="register-sidebar h-100">
                <div class="mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2.97 1.35A1 1 0 0 1 3.73 1h8.54a1 1 0 0 1 .76.35l2.609 3.044A1.5 1.5 0 0 1 16 5.37v.255a2.375 2.375 0 0 1-4.25 1.458A2.37 2.37 0 0 1 9.875 8 2.37 2.37 0 0 1 8 7.083 2.37 2.37 0 0 1 6.125 8a2.37 2.37 0 0 1-1.875-.917A2.375 2.375 0 0 1 0 5.625V5.37a1.5 1.5 0 0 1 .361-.976z"/>
                  </svg>
                </div>
                <h3 class="fw-bold mb-3">Join B2B Marketplace</h3>
                <p class="text-white-50 mb-4">Create your account and start trading with businesses worldwide.</p>
                <div class="mb-4">
                  <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width:36px;height:36px;flex-shrink:0;">🛒</div>
                    <div>
                      <strong class="small">Shop / Buyer</strong>
                      <p class="text-white-50 small mb-0">Browse products, send RFQs, manage orders</p>
                    </div>
                  </div>
                  <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success d-flex align-items-center justify-content-center me-3" style="width:36px;height:36px;flex-shrink:0;">📦</div>
                    <div>
                      <strong class="small">Supplier</strong>
                      <p class="text-white-50 small mb-0">List products, respond to RFQs, fulfill orders</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-7">
              <div class="card-body p-4 p-md-5">
                <h3 class="fw-bold mb-1">Create Account</h3>
                <p class="text-muted mb-4">Fill in your details to get started</p>
                <% if (error) { %>
                  <div class="alert alert-danger alert-dismissible py-2">
                    <small><%= error %></small>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
                  </div>
                <% } %>
                <form method="POST" action="/register">
                  <div class="mb-3">
                    <label class="form-label fw-semibold small">Account Type</label>
                    <div class="d-flex gap-3">
                      <div class="form-check flex-fill border rounded p-3">
                        <input class="form-check-input" type="radio" name="role" value="shop" id="roleShop" checked>
                        <label class="form-check-label w-100" for="roleShop">
                          <span class="fw-semibold">🛒 Shop / Buyer</span>
                        </label>
                      </div>
                      <div class="form-check flex-fill border rounded p-3">
                        <input class="form-check-input" type="radio" name="role" value="supplier" id="roleSupplier">
                        <label class="form-check-label w-100" for="roleSupplier">
                          <span class="fw-semibold">📦 Supplier</span>
                        </label>
                      </div>
                    </div>
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-semibold small">Business Name</label>
                    <input type="text" name="full_name" class="form-control" required minlength="2" maxlength="255">
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-semibold small">Email Address</label>
                    <input type="email" name="email" class="form-control" required>
                  </div>
                  <div class="row g-3 mb-3">
                    <div class="col-md-6">
                      <label class="form-label fw-semibold small">Password</label>
                      <input type="password" name="password" class="form-control" required minlength="6">
                      <div class="form-text">Min 6 characters</div>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label fw-semibold small">Confirm Password</label>
                      <input type="password" name="confirm_password" class="form-control" required minlength="6">
                    </div>
                  </div>
                  <div class="alert alert-info py-2 small mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-info-circle me-1" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/></svg>
                    New accounts require admin approval before you can log in.
                  </div>
                  <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">Create Account</button>
                </form>
                <div class="text-center mt-4">
                  <p class="text-muted mb-0 small">Already have an account? <a href="/login" class="fw-semibold">Sign in</a></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
