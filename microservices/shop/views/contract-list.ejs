<!DOCTYPE html>
<html>
<head>
  <title>My Contracts - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <h2>My Contracts</h2>
    <% if (contracts.length === 0) { %>
      <div class="alert alert-info">No contracts yet. Accept a quotation to create one.</div>
    <% } else { %>
    <table class="table table-hover mt-3">
      <thead class="table-dark">
        <tr><th>#</th><th>Product</th><th>Supplier</th><th>Qty</th><th>Total</th><th>Status</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% contracts.forEach(c => { %>
        <tr>
          <td><%= c.id %></td>
          <td><%= c.product_name %></td>
          <td><%= c.supplier_name %></td>
          <td><%= c.quantity %></td>
          <td>$<%= parseFloat(c.total_amount).toFixed(2) %></td>
          <td>
            <% if (c.status === 'draft') { %><span class="badge bg-warning">Draft</span>
            <% } else if (c.status === 'confirmed') { %><span class="badge bg-success">Confirmed</span>
            <% } else if (c.status === 'completed') { %><span class="badge bg-primary">Completed</span>
            <% } else { %><span class="badge bg-danger">Cancelled</span><% } %>
          </td>
          <td><a href="/contracts/<%= c.id %>" class="btn btn-sm btn-primary">View</a></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</body>
</html>
