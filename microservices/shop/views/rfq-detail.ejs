<!DOCTYPE html>
<html>
<head>
  <title>RFQ Detail - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <h2>RFQ #<%= rfq.id %></h2>
    <div class="row">
      <div class="col-md-6">
        <div class="card mb-3">
          <div class="card-header">Request Details</div>
          <div class="card-body">
            <p><strong>Product:</strong> <%= rfq.product_name %></p>
            <p><strong>List Price:</strong> $<%= parseFloat(rfq.list_price).toFixed(2) %></p>
            <p><strong>Requested Qty:</strong> <%= rfq.quantity %></p>
            <p><strong>Supplier:</strong> <%= rfq.supplier_name %></p>
            <p><strong>Status:</strong>
              <% if (rfq.status === 'pending') { %><span class="badge bg-warning">Pending</span>
              <% } else if (rfq.status === 'quoted') { %><span class="badge bg-info">Quoted</span>
              <% } else if (rfq.status === 'accepted') { %><span class="badge bg-success">Accepted</span>
              <% } else { %><span class="badge bg-secondary"><%= rfq.status %></span><% } %>
            </p>
            <% if (rfq.note) { %><p><strong>Note:</strong> <%= rfq.note %></p><% } %>
            <p><strong>Created:</strong> <%= new Date(rfq.created_at).toLocaleDateString() %></p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <% if (rfq.quote_id) { %>
        <div class="card mb-3 border-info">
          <div class="card-header bg-info text-white">Supplier's Quotation</div>
          <div class="card-body">
            <p><strong>Unit Price:</strong> $<%= parseFloat(rfq.quoted_price).toFixed(2) %></p>
            <p><strong>MOQ:</strong> <%= rfq.moq %> units</p>
            <p><strong>Delivery:</strong> <%= rfq.delivery_days %> days</p>
            <p><strong>Total Estimate:</strong> $<%= (parseFloat(rfq.quoted_price) * rfq.quantity).toFixed(2) %></p>
            <% if (rfq.quote_note) { %><p><strong>Note:</strong> <%= rfq.quote_note %></p><% } %>
            <p><strong>Quote Status:</strong>
              <% if (rfq.quote_status === 'pending') { %><span class="badge bg-warning">Awaiting Your Decision</span>
              <% } else if (rfq.quote_status === 'accepted') { %><span class="badge bg-success">Accepted</span>
              <% } else { %><span class="badge bg-danger">Rejected</span><% } %>
            </p>
            <% if (rfq.quote_status === 'pending') { %>
            <div class="mt-3">
              <form action="/rfqs/<%= rfq.id %>/accept/<%= rfq.quote_id %>" method="POST" class="d-inline">
                <button class="btn btn-success">Accept Quote & Create Contract</button>
              </form>
              <form action="/rfqs/<%= rfq.id %>/reject/<%= rfq.quote_id %>" method="POST" class="d-inline ms-2">
                <button class="btn btn-danger">Reject Quote</button>
              </form>
            </div>
            <% } %>
          </div>
        </div>
        <% } else { %>
        <div class="alert alert-warning">Waiting for supplier to submit a quotation...</div>
        <% } %>
      </div>
    </div>
    <a href="/rfqs" class="btn btn-secondary">Back to RFQs</a>
  </div>
</body>
</html>
