<!DOCTYPE html>
<html class="h-100">
<head>
  <title>Order #<%= order.id %> - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="d-flex flex-column h-100 bg-light">
  <%- include('partials/nav') %>
  <div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a href="/orders" class="text-decoration-none">My Orders</a></li>
        <li class="breadcrumb-item active">Order #<%= order.id %></li>
      </ol>
    </nav>

    <!-- Status Banner -->
    <div class="alert py-2 mb-4
      <% if (order.status === 'pending') { %> alert-warning
      <% } else if (order.status === 'confirmed') { %> alert-info
      <% } else if (order.status === 'paid') { %> alert-success
      <% } else if (order.status === 'cancelled') { %> alert-danger
      <% } else { %> alert-secondary <% } %>
    ">
      <div class="d-flex justify-content-between align-items-center">
        <span class="fw-semibold">
          <% if (order.status === 'pending') { %>⏳ Order pending supplier confirmation
          <% } else if (order.status === 'confirmed') { %>✅ Order confirmed — awaiting payment
          <% } else if (order.status === 'paid') { %>💰 Payment completed
          <% } else if (order.status === 'cancelled') { %>❌ Order cancelled
          <% } else { %>Status: <%= order.status %><% } %>
        </span>
        <span class="badge bg-white text-dark">Order #<%= order.id %></span>
      </div>
    </div>

    <!-- Order Progress -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between text-center position-relative">
          <% var steps = ['Placed', 'Confirmed', 'Paid'];
             var currentStep = order.status === 'pending' ? 0 : order.status === 'confirmed' ? 1 : order.status === 'paid' ? 2 : -1;
          %>
          <% steps.forEach(function(step, i) { %>
          <div class="flex-fill">
            <div class="mx-auto rounded-circle d-flex align-items-center justify-content-center mb-2
              <%= i <= currentStep ? 'bg-success text-white' : 'bg-light text-muted' %>"
              style="width:36px;height:36px;">
              <% if (i <= currentStep) { %>✓<% } else { %><%= i + 1 %><% } %>
            </div>
            <div class="small <%= i <= currentStep ? 'fw-semibold' : 'text-muted' %>"><%= step %></div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-8">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
          <div class="card-header bg-white border-bottom-0 pt-4 px-4">
            <h5 class="fw-bold mb-0">Order Details</h5>
          </div>
          <div class="card-body px-4 pb-4">
            <div class="row g-3">
              <div class="col-sm-6">
                <div class="small text-muted">Product</div>
                <div class="fw-semibold"><%= order.product_name %></div>
              </div>
              <div class="col-sm-6">
                <div class="small text-muted">Supplier</div>
                <div class="fw-semibold"><%= order.supplier_name %></div>
              </div>
              <div class="col-sm-6">
                <div class="small text-muted">Unit Price</div>
                <div class="fw-semibold">$<%= parseFloat(order.unit_price).toFixed(2) %></div>
              </div>
              <div class="col-sm-6">
                <div class="small text-muted">Quantity</div>
                <div class="fw-semibold"><%= order.quantity %> units</div>
              </div>
              <% if (order.note) { %>
              <div class="col-12">
                <div class="small text-muted">Note</div>
                <div class="bg-light rounded p-2 small"><%= order.note %></div>
              </div>
              <% } %>
              <div class="col-12">
                <div class="small text-muted">Order Date</div>
                <div class="small"><%= new Date(order.created_at).toLocaleString() %></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
          <div class="card-body p-4 text-center">
            <div class="small text-muted mb-1">Total Amount</div>
            <div class="fs-2 fw-bold text-success mb-3">$<%= parseFloat(order.total_price).toFixed(2) %></div>
            <div class="small text-muted"><%= order.quantity %> × $<%= parseFloat(order.unit_price).toFixed(2) %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-4">
      <a href="/orders" class="btn btn-outline-secondary">← Back to Orders</a>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
