<!DOCTYPE html>
<html>
<head>
  <title>B2B Marketplace - Shop</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <div class="jumbotron text-center p-5 bg-light rounded">
      <h1>Welcome to B2B Marketplace</h1>
      <p class="lead">Browse products from verified suppliers and place orders</p>
      <a href="/products" class="btn btn-primary btn-lg">Browse Products</a>
      <a href="/orders" class="btn btn-outline-secondary btn-lg ms-2">My Orders</a>
    </div>
    <div class="row mt-4">
      <div class="col-md-4">
        <div class="card">
          <div class="card-body text-center">
            <h5>📦 Products</h5>
            <p>Browse and search products from suppliers</p>
            <a href="/products" class="btn btn-sm btn-primary">View Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card">
          <div class="card-body text-center">
            <h5>🛒 Orders</h5>
            <p>View your order history and status</p>
            <a href="/orders" class="btn btn-sm btn-success">My Orders</a>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card">
          <div class="card-body text-center">
            <h5>🔧 Supplier Panel</h5>
            <p>Manage products and process orders</p>
            <a href="/admin/" class="btn btn-sm btn-warning">Go to Admin</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
