<!DOCTYPE html>
<html>
<head>
  <title>B2B Marketplace - Shop</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <div class="jumbotron text-center p-5 bg-light rounded">
      <h1>Welcome to B2B Marketplace</h1>
      <p class="lead">Browse products, send RFQs, negotiate quotes, and manage contracts</p>
      <a href="/products" class="btn btn-primary btn-lg">Browse Products</a>
      <a href="/rfqs" class="btn btn-outline-info btn-lg ms-2">My RFQs</a>
    </div>
    <div class="row mt-4">
      <div class="col-md-3">
        <div class="card">
          <div class="card-body text-center">
            <h5>Products</h5>
            <p>Browse and search supplier products</p>
            <a href="/products" class="btn btn-sm btn-primary">View Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body text-center">
            <h5>RFQs</h5>
            <p>Send requests for quotation</p>
            <a href="/rfqs" class="btn btn-sm btn-info">My RFQs</a>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body text-center">
            <h5>Contracts</h5>
            <p>View and manage contracts</p>
            <a href="/contracts" class="btn btn-sm btn-dark">Contracts</a>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body text-center">
            <h5>Orders</h5>
            <p>View order history and status</p>
            <a href="/orders" class="btn btn-sm btn-success">My Orders</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
