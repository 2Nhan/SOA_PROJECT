<!DOCTYPE html>
<html class="h-100">
<head>
  <title>Products - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    .product-card { border: none; border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s; overflow: hidden; }
    .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1); }
    .product-img-placeholder { height: 200px; background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%); display: flex; align-items: center; justify-content: center; }
    .product-img-placeholder svg { opacity: 0.3; }
  </style>
</head>
<body class="d-flex flex-column h-100 bg-light">
  <%- include('partials/nav') %>
  <div class="container mt-4 mb-5">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-1">Product Catalog</h2>
        <p class="text-muted mb-0">Browse products from verified suppliers</p>
      </div>
      <span class="badge bg-primary fs-6"><%= products.length %> product<%= products.length !== 1 ? 's' : '' %></span>
    </div>

    <!-- Search Bar -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
      <div class="card-body p-3">
        <form method="GET" action="/products">
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/></svg>
            </span>
            <input type="text" name="search" class="form-control border-start-0 py-2" placeholder="Search by product name, category, or supplier..." value="<%= keyword %>">
            <button class="btn btn-primary px-4" type="submit">Search</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="row g-4">
      <% if (products.length === 0) { %>
        <div class="col-12">
          <div class="text-center py-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#dee2e6" viewBox="0 0 16 16"><path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923z"/></svg>
            <p class="text-muted mt-3 mb-2">No products found</p>
            <% if (keyword) { %>
              <a href="/products" class="btn btn-outline-primary btn-sm">Clear search</a>
            <% } %>
          </div>
        </div>
      <% } %>
      <% products.forEach(function(p) { %>
        <div class="col-md-6 col-lg-4">
          <div class="card product-card shadow-sm h-100">
            <% if (p.image_url) { %>
              <img src="<%= p.image_url %>" class="card-img-top" alt="<%= p.name %>" style="height:200px; object-fit:cover;">
            <% } else { %>
              <div class="product-img-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16"><path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923z"/></svg>
              </div>
            <% } %>
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title fw-bold mb-0"><%= p.name %></h5>
                <span class="badge bg-light text-dark"><%= p.category %></span>
              </div>
              <p class="text-muted small flex-grow-1"><%= p.description ? p.description.substring(0, 100) + (p.description.length > 100 ? '...' : '') : 'No description available' %></p>
              <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fs-5 fw-bold text-success">$<%= parseFloat(p.price).toFixed(2) %></span>
                <span class="small text-muted">
                  <% if (p.stock > 0) { %>
                    <span class="text-success">● In Stock</span> (<%= p.stock %>)
                  <% } else { %>
                    <span class="text-danger">● Out of Stock</span>
                  <% } %>
                </span>
              </div>
              <div class="small text-muted mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-building me-1" viewBox="0 0 16 16"><path d="M4 2.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zM4 5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zM7.5 5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm2.5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zM4.5 8a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm2.5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5z"/><path d="M2 1a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1zm11 0H3v14h3v-2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5V15h3z"/></svg>
                <%= p.supplier_name %>
              </div>
              <div class="d-flex gap-2">
                <a href="/products/<%= p.id %>" class="btn btn-outline-primary btn-sm flex-fill">View Details</a>
                <% if (p.stock > 0) { %>
                  <a href="/orders/new/<%= p.id %>" class="btn btn-success btn-sm flex-fill">Order Now</a>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
