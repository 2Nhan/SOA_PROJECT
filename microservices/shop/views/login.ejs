<!DOCTYPE html>
<html class="h-100">
<head>
  <title>Login - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); }
    .login-card { border: none; border-radius: 16px; overflow: hidden; }
    .login-sidebar { background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); color: white; padding: 40px; display: flex; flex-direction: column; justify-content: center; }
  </style>
</head>
<body class="d-flex flex-column h-100">
  <div class="container my-auto">
    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="card login-card shadow-lg">
          <div class="row g-0">
            <div class="col-md-5 d-none d-md-block">
              <div class="login-sidebar h-100">
                <div class="mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2.97 1.35A1 1 0 0 1 3.73 1h8.54a1 1 0 0 1 .76.35l2.609 3.044A1.5 1.5 0 0 1 16 5.37v.255a2.375 2.375 0 0 1-4.25 1.458A2.37 2.37 0 0 1 9.875 8 2.37 2.37 0 0 1 8 7.083 2.37 2.37 0 0 1 6.125 8a2.37 2.37 0 0 1-1.875-.917A2.375 2.375 0 0 1 0 5.625V5.37a1.5 1.5 0 0 1 .361-.976z"/>
                  </svg>
                </div>
                <h3 class="fw-bold mb-3">B2B Marketplace</h3>
                <p class="text-white-50 mb-4">Connect with trusted suppliers, streamline procurement, and grow your businesses.</p>
                <ul class="list-unstyled small text-white-50">
                  <li class="mb-2">✓ Browse verified supplier products</li>
                  <li class="mb-2">✓ Send RFQs & negotiate prices</li>
                  <li class="mb-2">✓ Manage contracts digitally</li>
                  <li class="mb-2">✓ Track orders & payments</li>
                </ul>
              </div>
            </div>
            <div class="col-md-7">
              <div class="card-body p-4 p-md-5">
                <h3 class="fw-bold mb-1">Welcome back</h3>
                <p class="text-muted mb-4">Sign in to your account to continue</p>
                <% if (error) { %>
                  <div class="alert alert-<%= error.includes('successful') ? 'success' : 'danger' %> alert-dismissible py-2">
                    <small><%= error %></small>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
                  </div>
                <% } %>
                <form method="POST" action="/login">
                  <div class="mb-3">
                    <label class="form-label fw-semibold small">Email Address</label>
                    <div class="input-group">
                      <span class="input-group-text bg-light border-end-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6c757d" viewBox="0 0 16 16"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/></svg>
                      </span>
                      <input type="email" name="email" class="form-control border-start-0" required autofocus>
                    </div>
                  </div>
                  <div class="mb-4">
                    <label class="form-label fw-semibold small">Password</label>
                    <div class="input-group">
                      <span class="input-group-text bg-light border-end-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6c757d" viewBox="0 0 16 16"><path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2M5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1"/></svg>
                      </span>
                      <input type="password" name="password" class="form-control border-start-0" required>
                    </div>
                  </div>
                  <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">Sign In</button>
                </form>
                <div class="text-center mt-4">
                  <p class="text-muted mb-0 small">Don't have an account? <a href="/register" class="fw-semibold">Create one</a></p>
                </div>
                <hr class="my-4">
                <div class="bg-light rounded p-3">
                  <p class="fw-semibold small mb-2">Demo Accounts:</p>
                  <div class="row g-2 small text-muted">
                    <div class="col-12">🛒 <strong>Shop:</strong> shop1@b2bmarket.com / password123</div>
                    <div class="col-12">📦 <strong>Supplier:</strong> supplier1@b2bmarket.com / password123</div>
                    <div class="col-12">🛡️ <strong>Admin:</strong> admin@b2bmarket.com / password123</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
