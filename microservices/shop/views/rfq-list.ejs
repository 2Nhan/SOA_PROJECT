<!DOCTYPE html>
<html class="h-100">
<head>
  <title>My RFQs - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="d-flex flex-column h-100 bg-light">
  <%- include('partials/nav') %>
  <div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-1">My Requests for Quotation</h2>
        <p class="text-muted mb-0">Track your RFQ submissions and supplier responses</p>
      </div>
      <a href="/products" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/></svg>
        New RFQ
      </a>
    </div>

    <% if (rfqs.length === 0) { %>
      <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body text-center py-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#dee2e6" viewBox="0 0 16 16"><path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5"/><path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/></svg>
          <h5 class="text-muted mt-3">No RFQs yet</h5>
          <p class="text-muted">Browse products and send a Request for Quotation to get started.</p>
          <a href="/products" class="btn btn-primary">Browse Products</a>
        </div>
      </div>
    <% } else { %>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
      <% var pending = rfqs.filter(r => r.status === 'pending').length; %>
      <% var quoted = rfqs.filter(r => r.status === 'quoted').length; %>
      <% var accepted = rfqs.filter(r => r.status === 'accepted').length; %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:12px;">
          <div class="fs-3 fw-bold text-primary"><%= rfqs.length %></div>
          <div class="small text-muted">Total RFQs</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:12px;">
          <div class="fs-3 fw-bold text-warning"><%= pending %></div>
          <div class="small text-muted">Pending</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:12px;">
          <div class="fs-3 fw-bold text-info"><%= quoted %></div>
          <div class="small text-muted">Quoted</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:12px;">
          <div class="fs-3 fw-bold text-success"><%= accepted %></div>
          <div class="small text-muted">Accepted</div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:12px; overflow:hidden;">
      <table class="table table-hover mb-0 align-middle">
        <thead style="background:#f8f9fa;">
          <tr><th>#</th><th>Product</th><th>Supplier</th><th>Qty</th><th>Status</th><th>Quoted Price</th><th></th></tr>
        </thead>
        <tbody>
          <% rfqs.forEach(r => { %>
          <tr>
            <td class="fw-semibold">#<%= r.id %></td>
            <td><%= r.product_name %></td>
            <td class="text-muted"><%= r.supplier_name %></td>
            <td><%= r.quantity %></td>
            <td>
              <% if (r.status === 'pending') { %><span class="badge bg-warning bg-opacity-10 text-warning">Pending</span>
              <% } else if (r.status === 'quoted') { %><span class="badge bg-info bg-opacity-10 text-info">Quoted</span>
              <% } else if (r.status === 'accepted') { %><span class="badge bg-success bg-opacity-10 text-success">Accepted</span>
              <% } else if (r.status === 'rejected') { %><span class="badge bg-danger bg-opacity-10 text-danger">Rejected</span>
              <% } else { %><span class="badge bg-secondary"><%= r.status %></span><% } %>
            </td>
            <td><%= r.quoted_price ? '$' + parseFloat(r.quoted_price).toFixed(2) : '—' %></td>
            <td><a href="/rfqs/<%= r.id %>" class="btn btn-sm btn-outline-primary">View</a></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
