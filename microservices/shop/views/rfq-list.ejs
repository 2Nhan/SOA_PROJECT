<!DOCTYPE html>
<html>
<head>
  <title>My RFQs - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <h2>My Requests for Quotation</h2>
    <% if (rfqs.length === 0) { %>
      <div class="alert alert-info">No RFQs yet. <a href="/products">Browse products</a> to send an RFQ.</div>
    <% } else { %>
    <table class="table table-hover mt-3">
      <thead class="table-dark">
        <tr><th>#</th><th>Product</th><th>Supplier</th><th>Qty</th><th>Status</th><th>Quoted Price</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% rfqs.forEach(r => { %>
        <tr>
          <td><%= r.id %></td>
          <td><%= r.product_name %></td>
          <td><%= r.supplier_name %></td>
          <td><%= r.quantity %></td>
          <td>
            <% if (r.status === 'pending') { %><span class="badge bg-warning">Pending</span>
            <% } else if (r.status === 'quoted') { %><span class="badge bg-info">Quoted</span>
            <% } else if (r.status === 'accepted') { %><span class="badge bg-success">Accepted</span>
            <% } else if (r.status === 'rejected') { %><span class="badge bg-danger">Rejected</span>
            <% } else { %><span class="badge bg-secondary"><%= r.status %></span><% } %>
          </td>
          <td><%= r.quoted_price ? '$' + parseFloat(r.quoted_price).toFixed(2) : '-' %></td>
          <td><a href="/rfqs/<%= r.id %>" class="btn btn-sm btn-primary">View</a></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</body>
</html>
