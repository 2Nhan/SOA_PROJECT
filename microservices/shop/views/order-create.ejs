<!DOCTYPE html>
<html class="h-100">
<head>
  <title>New Order - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="d-flex flex-column h-100 bg-light">
  <%- include('partials/nav') %>
  <div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a href="/products" class="text-decoration-none">Products</a></li>
        <li class="breadcrumb-item"><a href="/products/<%= product.id %>" class="text-decoration-none"><%= product.name %></a></li>
        <li class="breadcrumb-item active">Place Order</li>
      </ol>
    </nav>

    <div class="row g-4">
      <div class="col-md-5">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
          <div class="card-body p-4">
            <h6 class="text-muted fw-semibold small text-uppercase mb-3">Product Summary</h6>
            <h5 class="fw-bold"><%= product.name %></h5>
            <div class="bg-light rounded p-3 mt-3">
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted small">Unit Price</span>
                <span class="fw-bold text-success">$<%= parseFloat(product.price).toFixed(2) %></span>
              </div>
              <div class="d-flex justify-content-between">
                <span class="text-muted small">Available Stock</span>
                <span class="fw-bold"><%= product.stock %> units</span>
              </div>
            </div>
            <div class="mt-4 p-3 border rounded">
              <h6 class="fw-semibold small mb-2">Order Total Preview</h6>
              <div id="orderPreview" class="text-center py-3">
                <div class="text-muted small">Enter quantity to see total</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-7">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
          <div class="card-body p-4">
            <h4 class="fw-bold mb-1">Place Order</h4>
            <p class="text-muted small mb-4">Fill in the details below to submit your order directly.</p>
            <form method="POST" action="/orders">
              <input type="hidden" name="product_id" value="<%= product.id %>">
              <div class="mb-3">
                <label class="form-label fw-semibold small">Quantity</label>
                <input type="number" name="quantity" id="orderQty" class="form-control" min="1" max="<%= product.stock %>" required>
                <div class="form-text">Maximum: <%= product.stock %> units</div>
              </div>
              <div class="mb-4">
                <label class="form-label fw-semibold small">Note <span class="text-muted">(optional)</span></label>
                <textarea name="note" class="form-control" rows="3"></textarea>
              </div>
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5"/></svg>
                  Submit Order
                </button>
                <a href="/products/<%= product.id %>" class="btn btn-outline-secondary px-4">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    var price = <%= parseFloat(product.price) %>;
    document.getElementById('orderQty').addEventListener('input', function() {
      var qty = parseInt(this.value) || 0;
      var preview = document.getElementById('orderPreview');
      if (qty > 0) {
        preview.innerHTML = '<div class="fs-3 fw-bold text-success">$' + (qty * price).toFixed(2) + '</div><div class="small text-muted">' + qty + ' × $' + price.toFixed(2) + '</div>';
      } else {
        preview.innerHTML = '<div class="text-muted small">Enter quantity to see total</div>';
      }
    });
  </script>
</body>
</html>
