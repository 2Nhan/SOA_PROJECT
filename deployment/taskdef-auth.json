{
    "family": "auth",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "auth",
            "image": "<IMAGE1_NAME>",
            "portMappings": [
                {
                    "containerPort": 8082,
                    "hostPort": 8082,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "APP_DB_HOST",
                    "value": "<RDS-ENDPOINT>"
                },
                {
                    "name": "APP_DB_USER",
                    "value": "admin"
                },
                {
                    "name": "APP_DB_PASSWORD",
                    "value": "lab-password"
                },
                {
                    "name": "APP_DB_NAME",
                    "value": "auth_db"
                },
                {
                    "name": "APP_DB_PORT",
                    "value": "3306"
                },
                {
                    "name": "SHOP_SERVICE_URL",
                    "value": "http://<ALB-DNS-NAME>"
                },
                {
                    "name": "SUPPLIER_SERVICE_URL",
                    "value": "http://<ALB-DNS-NAME>"
                },
                {
                    "name": "SESSION_DB_NAME",
                    "value": "auth_db"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/auth",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::<ACCOUNT-ID>:role/LabRole",
    "taskRoleArn": "arn:aws:iam::<ACCOUNT-ID>:role/LabRole"
}