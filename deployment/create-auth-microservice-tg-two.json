{
    "cluster": "b2b-marketplace",
    "serviceName": "auth-service",
    "taskDefinition": "auth:<REVISION-NUMBER>",
    "loadBalancers": [
        {
            "targetGroupArn": "<ARN-auth-tg-two>",
            "containerName": "auth",
            "containerPort": 8082
        }
    ],
    "desiredCount": 1,
    "launchType": "FARGATE",
    "platformVersion": "LATEST",
    "networkConfiguration": {
        "awsvpcConfiguration": {
            "subnets": [
                "<PUBLIC-SUBNET-1-ID>",
                "<PUBLIC-SUBNET-2-ID>"
            ],
            "securityGroups": [
                "<B2B-ECS-SG-ID>"
            ],
            "assignPublicIp": "ENABLED"
        }
    },
    "deploymentController": {
        "type": "CODE_DEPLOY"
    }
}